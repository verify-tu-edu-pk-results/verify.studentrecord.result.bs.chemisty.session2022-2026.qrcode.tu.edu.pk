rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // "results" holds one document per student result, keyed by its
    // verification token. Anyone can read a result (that's the whole
    // point of the public verification page) but only a signed-in
    // admin can create, edit, or delete one.
    match /results/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
